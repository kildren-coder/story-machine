# Copy to .sandcastle/.env and fill in. Never commit the filled file
# (.sandcastle/.gitignore ignores .env).

# Claude Code auth inside the sandbox. Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub token forwarded into the sandbox so the agent can comment on the
# issue when blocked. Host-side gh (issue picking, PR creation) uses your
# normal `gh auth login` and does NOT need this. Generate: gh auth token
GH_TOKEN=

# Research needs general web egress from inside the container. On this laptop
# Clash TUN usually proxies container traffic transparently; if the build-time
# connectivity check fails, uncomment to route explicitly through Clash:
# AFK_SANDBOX_PROXY=http://host.docker.internal:7890

# Optional overrides (defaults in afk.ts: research=claude-opus-4-8/xhigh,
# review=claude-opus-4-8/xhigh).
# AFK_RESEARCH_MODEL=claude-opus-4-8
# AFK_REVIEW_MODEL=claude-opus-4-8
# AFK_RESEARCH_EFFORT=xhigh
# AFK_REVIEW_EFFORT=xhigh

# Reserved for the coding-phase implement-AFK (not read yet — research/review
# agents above don't write code). Coding is execution-heavy, not open-ended
# judgment, so it gets a cheaper model and effort than research/review:
# AFK_IMPLEMENT_MODEL=claude-sonnet-5
# AFK_IMPLEMENT_EFFORT=high

# Quota gate (defaults in quota.ts; shared scale with agent-alert).
# AFK_QUOTA_STOP_PERCENT=90
# AFK_UNITS_PER_PERCENT=60000
# AFK_RATE_LIMITS_FILE=C:/Users/kildren/.claude/rate-limits.json
